# Copy to .env and fill in. NOTHING here is required for the offline unit tests, and the
# core Phase 0.5 historical backtest runs against free APIs (GeckoTerminal / DexScreener /
# RugCheck / Jupiter need no key). .env is gitignored — never commit real values.

# --- Channel under study -----------------------------------------------------------------
# The signal channel the harness evaluates. Scripts read runs/<CHANNEL>_corpus.json and
# pull_channel_history.py writes runs/<channel>_corpus.json, so keep these consistent.
CHANNEL=example_channel

# --- Telegram MCP (e.g. chigwell/telegram-mcp) — reads a channel's history (Phase 0.5) ---
# These are consumed by the MCP server itself (its own env), not by memebot directly.
#   1) Get api_id / api_hash at https://my.telegram.org/apps
#   2) Generate a session string with the MCP's session_string_generator (or any Telethon
#      string-session helper) and save the printed string.
#   3) Set TELEGRAM_EXPOSED_TOOLS=read-only — we only read; smallest blast radius.
# The account must have JOINED the signal channel. The session string == FULL account access.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_EXPOSED_TOOLS=read-only
# Optional: point pull_channel_history.py at a different .env file holding the creds above.
TELEGRAM_ENV_FILE=

# --- Production Telethon ingester (later phases, the 24/7 service the bot runs itself) ----
# Separate from the MCP. Uses a FILE-based session named <TG_SESSION_NAME>.session, which
# caches the login so you authenticate once. That .session file is gitignored and sensitive
# (it is full access to the account). This is what TG_SESSION_NAME refers to.
TG_API_ID=
TG_API_HASH=
TG_SESSION_NAME=memebot
TG_CHANNELS=          # comma-separated @usernames or numeric ids

# --- Dune Analytics (on-chain universe / wallet-discovery extension; src/memebot/data/dune.py)
# Free tier = 2,500 credits/mo per key. Two keys give credit/rate headroom. Keyless if unused.
DUNE_API_KEY=
DUNE_API_KEY_2=

# --- Optional paid / keyed data (denser OHLCV, holders, higher rate limits) ---------------
BIRDEYE_API_KEY=
HELIUS_API_KEY=
JUPITER_API_KEY=      # blank = keyless lite-api.jup.ag (~1 req/s); set to use api.jup.ag

# --- Live execution (later phases only; use a BURNER wallet, NEVER a main key) ------------
SOLANA_RPC_URL=
WALLET_PRIVATE_KEY=
